# =====================================================
# LogistiKita - Environment Configuration Example
# Database: MySQL via Laragon
# =====================================================

# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration (Laragon MySQL)
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=logistik_db

# Connection Pool Settings
DB_CONNECTION_LIMIT=10
DB_QUEUE_LIMIT=0

# SmartBank API (Payment Gateway Mock)
SMARTBANK_API_URL=https://smartbank.example.com/api
SMARTBANK_API_KEY=smartbank-dev-key-2026
